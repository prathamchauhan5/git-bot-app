# Server
PORT=3000

# Set to "production" on Render — enables Secure/SameSite=None cookies.
NODE_ENV=development

# Frontend origin (the Vercel URL in prod). Used for CORS + the post-login
# redirect. No trailing slash.
CLIENT_URL=http://localhost:5173

# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# In prod this is your Render URL, e.g. https://your-api.onrender.com/auth/github/callback
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# PostgreSQL connection string used by Prisma
DATABASE_URL=postgresql://user:password@localhost:5432/gitbot

# Secret used to sign JWT session cookies
JWT_SECRET=

# Webhook signature secret. Set the SAME value in the GitHub webhook config.
# When set, incoming webhooks must carry a valid X-Hub-Signature-256.
# Leave empty in local dev (e.g. via smee) to skip verification.
GITHUB_WEBHOOK_SECRET=